// This is your Prisma schema file.
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model Bulletin {
  id            String   @id @default(cuid())

  // SLF bulletin ID (from API)
  bulletinId    String   @unique

  // Raw GeoJSON feature from SLF API
  rawData       Json     @db.JsonB

  // Claude-generated summary (BulletinAnalysis JSON)
  summary       Json     @db.JsonB

  // Region metadata
  regionIds     String[] // Array of region IDs covered by this bulletin
  regionNames   String[] // Array of region names

  // Metadata from bulletin
  issuedAt      DateTime
  validFrom     DateTime
  validTo       DateTime
  nextUpdate    DateTime?
  lang          String   @default("en")
  unscheduled   Boolean  @default(false)

  // When we fetched this
  fetchedAt     DateTime @default(now())

  @@unique([bulletinId, issuedAt])
  @@index([fetchedAt])
  @@index([issuedAt])
}
